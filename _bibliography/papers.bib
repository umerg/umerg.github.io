@inproceedings{gupta2026autoregressive,
  abbr        = {ICLR-W},
  bibtex_show = {true},
  selected    = {true},
  title       = {Autoregressive Frontier Expansion: Growing Trees with Graph Machine Learning},
  author      = {Gupta, Umer and [co-authors] and [senior authors]},
  booktitle   = {GRaM Workshop, International Conference on Learning Representations (ICLR)},
  year        = {2026},
  month       = {April},
  location    = {Rio de Janeiro, Brazil},
  abstract    = {We introduce an autoregressive process that jointly generates the topology and 3D geometry of branching biological morphologies. At each step the model decides whether to expand each frontier node and, if so, places new child nodes using a diffusion process over an SO(2)-equivariant message-passing network expressed in parent-centric local frames. We further condition generation on multi-filtration zero-dimensional persistent homology to inject topological priors. We demonstrate the approach on botanical tree crowns, with extensions to neuronal morphologies in follow-up work.}
}
